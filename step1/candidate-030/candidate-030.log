r {\n            text-align: center;\n            background: var(--card-bg);\n            padding: 2rem;\n            border-radius: 20px;\n            box-shadow: 0 0 30px rgba(0, 242, 255, 0.2);\n            border: 1px solid #333;\n            max-width: 450px;\n            width: 90%;\n        }\n\n        h1 {\n            margin-top: 0;\n            font-size: 1.5rem;\n            text-transform: uppercase;\n            letter-spacing: 2px;\n            color: var(--neon-blue);\n        }\n\n        .stats {\n            display: flex;\n            justify-content: space-around;\n            margin-bottom: 1.5rem;\n            font-weight: bold;\n            font-family: monospace;\n            background: #000;\n            padding: 10px;\n            border-radius: 8px;\n            border: 1px inset #444;\n        }\n\n        .token-count { color: #50ff50; }\n\n        .slot-machine {\n            display: grid;\n            grid-template-columns: repeat(3, 1fr);\n            gap: 10px;\n            background: #111;\n            padding: 15px;\n            border-radius: 12px;\n            margin-bottom: 1.5rem;\n            border: 4px solid #333;\n        }\n\n        .reel {\n            height: 100px;\n            background: white;\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 3rem;\n            color: #000;\n            overflow: hidden;\n            position: relative;\n        }\n\n        .reel.spinning {\n            animation: blur 0.1s infinite;\n        }\n\n        @keyframes blur {\n            0% { filter: blur(0px); transform: translateY(-2px); }\n            50% { filter: blur(4px); }\n            100% { filter: blur(0px); transform: translateY(2px); }\n        }\n\n        button {\n            background: linear-gradient(45deg, var(--neon-purple), var(--neon-blue));\n            border: none;\n            color: white;\n     